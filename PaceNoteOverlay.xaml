<Window x:Class="LMUWeaver.PaceNoteOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LMUWeaver"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" IsHitTestVisible="False" ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Title="LMUNote">
    <StackPanel Margin="40,24" HorizontalAlignment="Center" VerticalAlignment="Center">
        <!-- Large symbol glyph, e.g. "← 3" or "⌒ CREST" -->
        <local:OutlinedTextBlock x:Name="TxtSymbol"
                                  FontSize="88"
                                  StrokeThickness="6"
                                  HorizontalAlignment="Center"
                                  Margin="0,0,0,6"/>
        <!-- Supporting text line -->
        <local:OutlinedTextBlock x:Name="TxtNote"
                                  FontSize="46"
                                  StrokeThickness="5"
                                  HorizontalAlignment="Center"/>
    </StackPanel>
</Window>
