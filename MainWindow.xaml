<Window x:Class="LMUWeaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LMU Beeper Pro" Height="540" Width="300" MinHeight="300" MinWidth="260"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" MouseDown="Window_MouseDown">

    <Window.Resources>
        <DrawingBrush x:Key="CarbonBrush" TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#080808">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#151515">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4" />
                                <RectangleGeometry Rect="4,4,4,4" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="MetroSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Cursor="Hand">
                            <Border x:Name="SwitchBorder" Width="32" Height="16" CornerRadius="8" Background="#333333" VerticalAlignment="Center">
                                <Ellipse x:Name="SwitchThumb" Width="12" Height="12" Fill="#888888" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBorder" Property="Background" Value="#FF00FFCC"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,2,0"/>
                                <Setter TargetName="SwitchThumb" Property="Fill" Value="#000000"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Separate background layer so opacity doesn't affect content -->
        <Border x:Name="BackgroundLayer" Background="{StaticResource CarbonBrush}" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="0"/>
        <Border Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Width="20" Height="20" Background="Transparent" Foreground="#88FFFFFF" FontSize="12" Margin="0,-5,-5,0"/>

                <StackPanel Grid.Row="0">
                    <TextBlock x:Name="TxtTrack" Text="WAITING FOR SESSION..." Foreground="#FF888888" FontSize="10" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Center"/>

                    <TextBlock Text="NEXT BRAKE POINT" Foreground="#FF555555" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,0"/>
                    <TextBlock x:Name="TxtNextBrake" Text="--- m" Foreground="#FFFF8C00" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-5,0,0"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,5">
                        <TextBlock Text="LAP DISTANCE:" Foreground="#FF666666" FontSize="9" VerticalAlignment="Center" Margin="0,0,5,0" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtDistance" Text="0.0 m" Foreground="#FF00FFCC" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <ProgressBar x:Name="BarGas" Minimum="0" Maximum="1" Height="6" Foreground="#FF00D000" Background="#22000000" BorderThickness="0" Margin="0,0,0,2"/>
                    <ProgressBar x:Name="BarBrake" Minimum="0" Maximum="1" Height="6" Foreground="#FFD00000" Background="#22000000" BorderThickness="0"/>
                </StackPanel>

                <Button x:Name="BtnToggleSettings" Grid.Row="2" Content="▼ SETTINGS" Click="BtnToggleSettings_Click" Background="Transparent" Foreground="#FF555555" FontSize="10" FontWeight="Bold" Margin="0,0,0,5" HorizontalAlignment="Left"/>

                <Grid x:Name="SettingsContainer" Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="SET BRAKING POINT" Click="BtnAddPoint_Click" Height="30" Background="#FF00FFCC" Foreground="Black" FontWeight="Bold" Margin="0,0,0,10"/>

                    <ListBox x:Name="ListPoints" Grid.Row="1" Background="#11FFFFFF" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1" Padding="5">
                                    <Grid Width="230">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Distance, StringFormat={}{0:F1} m}" VerticalAlignment="Center" FontSize="13" FontWeight="Bold" Foreground="#FFFF8C00"/>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="-" Click="BtnMinus_Click" Tag="{Binding}" Width="20" Height="20" Margin="0,0,2,0"/>
                                            <Button Content="+" Click="BtnPlus_Click" Tag="{Binding}" Width="20" Height="20" Margin="0,0,8,0"/>
                                            <Button Content="✕" Click="BtnDeletePoint_Click" Tag="{Binding}" Width="20" Height="20" Background="Transparent" Foreground="#FF4444"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Center">
                            <CheckBox x:Name="ToggleBrake" Content="BRAKE BEEPS" Style="{StaticResource MetroSwitch}" IsChecked="True" Checked="ToggleBrake_Changed" Unchecked="ToggleBrake_Changed" Margin="0,0,15,0"/>
                            <CheckBox x:Name="ToggleShift" Content="SHIFT BEEP" Style="{StaticResource MetroSwitch}" IsChecked="True" Checked="ToggleShift_Changed" Unchecked="ToggleShift_Changed"/>
                        </StackPanel>

                        <TextBlock Text="WARNING DISTANCES (m)" Foreground="#FF666666" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Beep 1:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderWarn1" Grid.Column="1" Minimum="10" Maximum="300" Value="100" Margin="5,0" ValueChanged="SliderWarn1_ValueChanged"/>
                            <TextBlock x:Name="TxtWarn1" Grid.Column="2" Text="100" Foreground="#FFFF8C00" FontSize="10" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Beep 2:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderWarn2" Grid.Column="1" Minimum="1" Maximum="90" Value="50" Margin="5,0" ValueChanged="SliderWarn2_ValueChanged"/>
                            <TextBlock x:Name="TxtWarn2" Grid.Column="2" Text="50" Foreground="#FFFF8C00" FontSize="10" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="SHIFT INDICATOR (%)" Foreground="#FF666666" FontSize="9" FontWeight="Bold" Margin="0,5,0,2"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Trigger:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderShift" Grid.Column="1" Minimum="88" Maximum="100" Value="97" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="5,0" ValueChanged="SliderShift_ValueChanged"/>
                            <TextBlock x:Name="TxtShift" Grid.Column="2" Text="97.0%" Foreground="#FF00FFCC" FontSize="10" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,10,0,0">
                        <TextBlock Text="BACKGROUND OPACITY" Foreground="#FF666666" FontSize="9" FontWeight="Bold" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Alpha:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderBgOpacity" Grid.Column="1" Minimum="0" Maximum="100" Value="100" TickFrequency="1" IsSnapToTickEnabled="True" Margin="5,0" ValueChanged="SliderBgOpacity_ValueChanged"/>
                            <TextBlock x:Name="TxtBgOpacity" Grid.Column="2" Text="100%" Foreground="#FF00FFCC" FontSize="10" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="IMPORT FILE" Click="BtnImportFile_Click" Background="#FF333333" Height="25" FontSize="10" FontWeight="Bold" Margin="0,0,2,0"/>
                            <Button Content="SAVE LOCAL" Click="BtnExport_Click" Grid.Column="1" Background="#FF333333" Height="25" FontSize="10" FontWeight="Bold" Margin="2,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Thumb Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="ResizeThumb_DragDelta" Margin="0,0,2,2">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Path Data="M 0,12 L 12,0 L 12,12 Z" Fill="#44FFFFFF"/>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</Window>
