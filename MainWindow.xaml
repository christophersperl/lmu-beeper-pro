<Window x:Class="LMUWeaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LMU Beeper Pro" Height="480" Width="280" MinHeight="160" MinWidth="220"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" MouseDown="Window_MouseDown">

    <Window.Resources>
        <DrawingBrush x:Key="CarbonBrush" TileMode="Tile" Viewport="0,0,8,8" ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#080808">
                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,8,8"/></GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#151515">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4"/>
                                <RectangleGeometry Rect="4,4,4,4"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Compact pill toggle for visibility chips -->
        <Style x:Key="VisChip" TargetType="ToggleButton">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="#FF555555"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2800FFCC"/>
                                <Setter Property="Foreground" Value="#FF00FFCC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MetroSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFAAAAAA"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Cursor="Hand">
                            <Border x:Name="SwitchBorder" Width="28" Height="14" CornerRadius="7" Background="#333333" VerticalAlignment="Center">
                                <Ellipse x:Name="SwitchThumb" Width="10" Height="10" Fill="#888888" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                            </Border>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBorder" Property="Background" Value="#FF00FFCC"/>
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,2,0"/>
                                <Setter TargetName="SwitchThumb" Property="Fill" Value="#000000"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="2" Padding="6,0,20,0">
                                <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                    Content="{TemplateBinding SelectionBoxItem}"
                                    ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <Path Data="M 0,0 L 4,4 L 8,0 Z" Fill="#FF888888" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <ToggleButton Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent" BorderThickness="0" Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"
                                          Cursor="Hand" Opacity="0"/>
                            <Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#1A1A1A" BorderBrush="#44FFFFFF" BorderThickness="1" CornerRadius="2" MinWidth="{TemplateBinding ActualWidth}">
                                    <ItemsPresenter/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFCCCCCC"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="8,3"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemBd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#FF00FFCC"/>
                                            <Setter Property="Foreground" Value="Black"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemBd" Property="Background" Value="#2200FFCC"/>
                                            <Setter Property="Foreground" Value="#FF00FFCC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="BackgroundLayer" Background="{StaticResource CarbonBrush}" BorderBrush="#33FFFFFF" BorderThickness="1"/>
        <Border x:Name="ContentBorder" Padding="8">
            <Border.LayoutTransform>
                <ScaleTransform x:Name="UiScale" ScaleX="1" ScaleY="1"/>
            </Border.LayoutTransform>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: main display -->
                    <RowDefinition Height="Auto"/>  <!-- 1: trail -->
                    <RowDefinition Height="Auto"/>  <!-- 2: RPM bar -->
                    <RowDefinition Height="Auto"/>  <!-- 3: visibility chips -->
                    <RowDefinition Height="*"/>     <!-- 4: settings panel -->
                    <RowDefinition Height="Auto"/>  <!-- 5: footer -->
                </Grid.RowDefinitions>

                <!-- Close button floats top-right over row 0 -->
                <Button Content="✕" Click="BtnClose_Click" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="18" Height="18" Background="Transparent" Foreground="#66FFFFFF" FontSize="11" Margin="0,-3,-3,0"/>

                <!-- ROW 0: Main display -->
                <StackPanel Grid.Row="0" Margin="0,0,0,2">
                    <StackPanel x:Name="PanelTrack">
                        <TextBlock x:Name="TxtTrack" Text="WAITING FOR SESSION..." Foreground="#FF888888"
                                   FontSize="9" FontWeight="Bold" Margin="0,0,0,2" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Gang + Geschwindigkeit + Einbremsgeschwindigkeit -->
                    <Grid x:Name="PanelGearSpeed" Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="TxtGear" Grid.Column="0" Text="—" FontSize="32" FontWeight="Bold"
                                   Foreground="#FF00FFCC" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Width="1" Background="#22FFFFFF" Margin="6,4"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtSpeed" Text="— km/h" FontSize="13" FontWeight="Bold" Foreground="#FFDDDDDD"/>
                            <StackPanel x:Name="PanelEntrySpeed" Orientation="Horizontal" Margin="0,1,0,0">
                                <TextBlock Text="ENTRY " Foreground="#FF444444" FontSize="8" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtEntrySpeed" Text="—" Foreground="#FF888888" FontSize="8" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <StackPanel x:Name="PanelNextBrake" HorizontalAlignment="Center">
                        <TextBlock Text="NEXT BRAKE POINT" Foreground="#FF444444" FontSize="8" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtNextBrake" Text="--- m" Foreground="#FFFF8C00" FontSize="30"
                                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,-3,0,0"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelLapDist" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,1,0,2">
                        <TextBlock Text="LAP DIST:" Foreground="#FF555555" FontSize="8" VerticalAlignment="Center"
                                   Margin="0,0,4,0" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtDistance" Text="0.0 m" Foreground="#FF00FFCC" FontSize="11"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- ROW 1: Trail graph -->
                <Canvas x:Name="TrailCanvas" Grid.Row="1" Height="50" Margin="0,0,0,4"
                        Background="#0CFFFFFF" ClipToBounds="True">
                    <Line X1="0" Y1="25" X2="9999" Y2="25" Stroke="#18FFFFFF" StrokeThickness="1"/>
                    <Polyline x:Name="TrailThrottle" Stroke="#CC00D000" StrokeThickness="1.5" StrokeLineJoin="Round"/>
                    <Polyline x:Name="TrailBrake"    Stroke="#CCD00000" StrokeThickness="1.5" StrokeLineJoin="Round"/>
                    <TextBlock Text="GAS" Foreground="#3300D000" FontSize="7" FontWeight="Bold" Canvas.Left="3" Canvas.Top="2"/>
                    <TextBlock Text="BRK" Foreground="#33D00000" FontSize="7" FontWeight="Bold" Canvas.Left="3" Canvas.Top="12"/>
                </Canvas>

                <!-- ROW 2: RPM Shift bar -->
                <Canvas x:Name="RpmCanvas" Grid.Row="2" Height="7" Margin="0,0,0,4" ClipToBounds="True">
                    <Border x:Name="RpmBg"     Background="#12FFFFFF" Width="9999" Height="7"/>
                    <Border x:Name="RpmFill"   Height="7" Width="0"/>
                    <Border x:Name="RpmMarker" Background="#88FFFFFF" Width="2" Height="7"/>
                </Canvas>

                <!-- ROW 3: Visibility chips -->
                <WrapPanel Grid.Row="3" Margin="0,0,0,4" Orientation="Horizontal">
                    <ToggleButton x:Name="VtTrack"   Content="TRACK"   IsChecked="True"  Style="{StaticResource VisChip}" Click="VtTrack_Click"   Margin="0,0,3,3"/>
                    <ToggleButton x:Name="VtGear"    Content="GEAR"    IsChecked="True"  Style="{StaticResource VisChip}" Click="VtGear_Click"    Margin="0,0,3,3"/>
                    <ToggleButton x:Name="VtNext"    Content="NEXT"    IsChecked="True"  Style="{StaticResource VisChip}" Click="VtNext_Click"    Margin="0,0,3,3"/>
                    <ToggleButton x:Name="VtDist"    Content="DIST"    IsChecked="True"  Style="{StaticResource VisChip}" Click="VtDist_Click"    Margin="0,0,3,3"/>
                    <ToggleButton x:Name="VtTrail"   Content="TRAIL"   IsChecked="True"  Style="{StaticResource VisChip}" Click="VtTrail_Click"   Margin="0,0,3,3"/>
                    <ToggleButton x:Name="VtRpm"     Content="RPM"     IsChecked="True"  Style="{StaticResource VisChip}" Click="VtRpm_Click"     Margin="0,0,3,3"/>
                    <ToggleButton x:Name="VtBspd"    Content="BSPD"    IsChecked="True"  Style="{StaticResource VisChip}" Click="VtBspd_Click"    Margin="0,0,3,3"/>
                    <ToggleButton x:Name="VtOverlay" Content="OVERLAY" IsChecked="False" Style="{StaticResource VisChip}" Click="VtOverlay_Click" Margin="0,0,0,3"/>
                </WrapPanel>

                <!-- ROW 4: Settings panel (all sections, independently collapsible) -->
                <StackPanel x:Name="SettingsPanel" Grid.Row="4">

                    <!-- ═══ BREAKPOINTS ════════════════════════════════════════ -->
                    <Grid Margin="0,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnToggleBreakpoints" Content="▼ BREAKPOINTS"
                                Click="BtnToggleBreakpoints_Click" HorizontalAlignment="Left"
                                Background="Transparent" Foreground="#FF888888"
                                FontSize="9" FontWeight="Bold" Padding="0" BorderThickness="0" Cursor="Hand"/>
                        <Button Content="+ SET HERE" Click="BtnAddPoint_Click" Grid.Column="1"
                                Height="18" Padding="6,0" FontSize="8" FontWeight="Bold"
                                Background="#FF00FFCC" Foreground="Black"/>
                    </Grid>

                    <StackPanel x:Name="BreakpointsContainer" Margin="0,0,0,4">
                        <ListBox x:Name="ListPoints" MaxHeight="120" Background="#0CFFFFFF" BorderThickness="0"
                                 Foreground="White" HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#1AFFFFFF" BorderThickness="0,0,0,1" Padding="6,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Distance, StringFormat={}{0:F1} m}"
                                                           FontSize="14" FontWeight="Bold" Foreground="#FFFF8C00"/>
                                                <TextBlock Text="{Binding Description}"
                                                           FontSize="8" Foreground="#FF555555" Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="−" Click="BtnMinus_Click" Tag="{Binding}" Width="22" Height="22" Margin="0,0,2,0"/>
                                                <Button Content="+" Click="BtnPlus_Click"  Tag="{Binding}" Width="22" Height="22" Margin="0,0,4,0"/>
                                                <Button Content="✕" Click="BtnDeletePoint_Click" Tag="{Binding}" Width="20" Height="20" Background="Transparent" Foreground="#FF4444"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <!-- ═══ NOTES ══════════════════════════════════════════════ -->
                    <Rectangle Fill="#18FFFFFF" Height="1" Margin="0,0,0,3"/>
                    <Button x:Name="BtnToggleNotes" Content="▶ NOTES"
                            Click="BtnToggleNotes_Click" HorizontalAlignment="Left"
                            Background="Transparent" Foreground="#FF888888"
                            FontSize="9" FontWeight="Bold" Padding="0" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,0,2"/>

                    <StackPanel x:Name="NotesContainer" Visibility="Collapsed" Margin="0,0,0,4">

                        <!-- Add note at current position -->
                        <Button Content="ADD NOTE HERE" Click="BtnAddNote_Click"
                                Height="24" Background="#FF1A3A2A" Foreground="#FF00FFCC"
                                FontWeight="Bold" FontSize="9" Margin="0,0,0,4"/>

                        <!-- Note list -->
                        <ListBox x:Name="ListNotes" MaxHeight="110" Background="#0DFFFFFF" BorderThickness="0"
                                 Foreground="White" HorizontalContentAlignment="Stretch"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectionChanged="ListNotes_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="NoteItemBd" Background="Transparent">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="NoteItemBd" Property="Background" Value="#2200FFCC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#1AFFFFFF" BorderThickness="0,0,0,1" Padding="5,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="20"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Symbol code (short) -->
                                            <TextBlock Grid.Column="0" Text="{Binding Symbol}"
                                                       FontSize="9" FontWeight="Bold" Foreground="#FF00FFCC"
                                                       VerticalAlignment="Center"/>
                                            <!-- Distance -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Distance, StringFormat={}{0:F0}m}"
                                                       FontSize="9" FontWeight="Bold" Foreground="#FFFF8C00"
                                                       VerticalAlignment="Center"/>
                                            <!-- Text preview -->
                                            <TextBlock Grid.Column="2" Text="{Binding Text}"
                                                       FontSize="9" Foreground="#FFAAAAAA"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <!-- Delete -->
                                            <Button Grid.Column="3" Content="✕" Tag="{Binding}"
                                                    Click="BtnDeleteNote_Click"
                                                    Width="18" Height="18" FontSize="8"
                                                    Background="Transparent" Foreground="#FF4444"
                                                    VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Inline editor (hidden until add/edit) -->
                        <Border x:Name="NoteEditor" Visibility="Collapsed"
                                Background="#18FFFFFF" CornerRadius="3"
                                Padding="6" Margin="0,4,0,0">
                            <StackPanel>
                                <!-- Symbol row -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Symbol:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                                    <ComboBox x:Name="ComboNoteSymbol" Grid.Column="1"
                                              Style="{StaticResource DarkCombo}">
                                        <ComboBoxItem Content="L1" IsSelected="False"/>
                                        <ComboBoxItem Content="L2"/>
                                        <ComboBoxItem Content="L3"/>
                                        <ComboBoxItem Content="L4"/>
                                        <ComboBoxItem Content="L5"/>
                                        <ComboBoxItem Content="L6"/>
                                        <ComboBoxItem Content="R1"/>
                                        <ComboBoxItem Content="R2"/>
                                        <ComboBoxItem Content="R3"/>
                                        <ComboBoxItem Content="R4"/>
                                        <ComboBoxItem Content="R5"/>
                                        <ComboBoxItem Content="R6"/>
                                        <ComboBoxItem Content="CREST"/>
                                        <ComboBoxItem Content="JUMP"/>
                                        <ComboBoxItem Content="HAIRPIN L"/>
                                        <ComboBoxItem Content="HAIRPIN R"/>
                                        <ComboBoxItem Content="CHICANE"/>
                                        <ComboBoxItem Content="CAUTION"/>
                                        <ComboBoxItem Content="FLAT"/>
                                        <ComboBoxItem Content="NARROW"/>
                                        <ComboBoxItem Content="BRIDGE"/>
                                        <ComboBoxItem Content="NOTE"/>
                                    </ComboBox>
                                </Grid>
                                <!-- Text row -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Text:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBox x:Name="TxtNoteText" Grid.Column="1"
                                             Background="#22FFFFFF" Foreground="White" BorderThickness="0"
                                             FontSize="10" FontWeight="Bold" Padding="4,2"
                                             CaretBrush="White"/>
                                </Grid>
                                <!-- Distance row -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="18"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Dist:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtEditorDist" Grid.Column="1"
                                               Foreground="#FFFF8C00" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button Content="−" Grid.Column="2" Click="BtnNoteDistMinus_Click"
                                            Width="16" Height="16" FontSize="10" Padding="0" Margin="2,0,0,0"/>
                                    <Button Content="+" Grid.Column="3" Click="BtnNoteDistPlus_Click"
                                            Width="16" Height="16" FontSize="10" Padding="0" Margin="2,0,0,0"/>
                                </Grid>
                                <!-- Save / Cancel -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="✓ SAVE" Click="BtnSaveNote_Click"
                                            Height="22" Background="#FF00CC88" Foreground="Black"
                                            FontWeight="Bold" FontSize="9" Margin="0,0,2,0"/>
                                    <Button Content="✕ CANCEL" Grid.Column="1" Click="BtnCancelNote_Click"
                                            Height="22" Background="#FF333333" FontSize="9" FontWeight="Bold" Margin="2,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Global note settings -->
                        <TextBlock Text="DISPLAY DURATION" Foreground="#FF555555" FontSize="8" FontWeight="Bold" Margin="0,8,0,2"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="SliderNoteDuration" Minimum="1" Maximum="10" Value="3"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    ValueChanged="SliderNoteDuration_ValueChanged"/>
                            <TextBlock x:Name="TxtNoteDuration" Grid.Column="1"
                                       Text="3.0 s" Foreground="#FF00FFCC" FontSize="10" FontWeight="Bold"
                                       TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="ToggleNoteTts" Content="TEXT TO SPEECH"
                                      Style="{StaticResource MetroSwitch}"
                                      IsChecked="True"
                                      Checked="ToggleNoteTts_Changed" Unchecked="ToggleNoteTts_Changed"/>
                            <Button Content="▶ TEST" Click="BtnTestNote_Click" Grid.Column="1"
                                    Height="18" Padding="6,0" FontSize="8" FontWeight="Bold"
                                    Background="#22FFFFFF" Foreground="#FFAAAAAA"/>
                        </Grid>
                    </StackPanel>

                    <!-- ═══ SOUND ══════════════════════════════════════════════ -->
                    <Rectangle Fill="#18FFFFFF" Height="1" Margin="0,0,0,3"/>
                    <Button x:Name="BtnToggleSound" Content="▼ SOUND"
                            Click="BtnToggleSound_Click" HorizontalAlignment="Left"
                            Background="Transparent" Foreground="#FF888888"
                            FontSize="9" FontWeight="Bold" Padding="0" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,0,2"/>

                    <StackPanel x:Name="SoundContainer" Margin="0,0,0,4">
                        <!-- Sound toggles -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" HorizontalAlignment="Center">
                            <CheckBox x:Name="ToggleBrake" Content="BRAKE BEEPS" Style="{StaticResource MetroSwitch}"
                                      IsChecked="True" Checked="ToggleBrake_Changed" Unchecked="ToggleBrake_Changed" Margin="0,0,12,0"/>
                            <CheckBox x:Name="ToggleShift" Content="SHIFT BEEP" Style="{StaticResource MetroSwitch}"
                                      IsChecked="True" Checked="ToggleShift_Changed" Unchecked="ToggleShift_Changed"/>
                        </StackPanel>

                        <!-- Brake preset -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Brake:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ComboBrakePreset" Grid.Column="1" Style="{StaticResource DarkCombo}" SelectionChanged="ComboBrakePreset_SelectionChanged">
                                <ComboBoxItem Content="Earcon" IsSelected="True"/>
                                <ComboBoxItem Content="GT"/>
                                <ComboBoxItem Content="Chime"/>
                                <ComboBoxItem Content="Classic"/>
                                <ComboBoxItem Content="Radar"/>
                                <ComboBoxItem Content="Alert"/>
                            </ComboBox>
                        </Grid>

                        <!-- Warning distances -->
                        <TextBlock Text="WARNING DISTANCES (m)" Foreground="#FF555555" FontSize="8" FontWeight="Bold" Margin="0,6,0,2"/>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Beep 1:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderWarn1" Grid.Column="1" Minimum="10" Maximum="300" Value="100" Margin="4,0" ValueChanged="SliderWarn1_ValueChanged"/>
                            <TextBlock x:Name="TxtWarn1" Grid.Column="2" Text="100" Foreground="#FFFF8C00" FontSize="10" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="62"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Beep 2 (Lift):" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderWarn2" Grid.Column="1" Minimum="1" Maximum="90" Value="35" Margin="4,0" ValueChanged="SliderWarn2_ValueChanged"/>
                            <TextBlock x:Name="TxtWarn2" Grid.Column="2" Text="35" Foreground="#FFFF8C00" FontSize="10" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Shift indicator -->
                        <TextBlock Text="SHIFT INDICATOR (%)" Foreground="#FF555555" FontSize="8" FontWeight="Bold" Margin="0,2,0,2"/>
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="38"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Trigger:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderShift" Grid.Column="1" Minimum="88" Maximum="100" Value="97"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="4,0" ValueChanged="SliderShift_ValueChanged"/>
                            <TextBlock x:Name="TxtShift" Grid.Column="2" Text="97.0%" Foreground="#FF00FFCC" FontSize="10" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Shift preset -->
                        <Grid Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Shift:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ComboShiftPreset" Grid.Column="1" Style="{StaticResource DarkCombo}" SelectionChanged="ComboShiftPreset_SelectionChanged">
                                <ComboBoxItem Content="Bell" IsSelected="True"/>
                                <ComboBoxItem Content="Ding"/>
                                <ComboBoxItem Content="Double"/>
                                <ComboBoxItem Content="Single"/>
                                <ComboBoxItem Content="Triple"/>
                                <ComboBoxItem Content="Buzz"/>
                            </ComboBox>
                        </Grid>
                    </StackPanel>

                    <!-- ═══ DISPLAY ════════════════════════════════════════════ -->
                    <Rectangle Fill="#18FFFFFF" Height="1" Margin="0,0,0,3"/>
                    <Button x:Name="BtnToggleDisplay" Content="▶ DISPLAY"
                            Click="BtnToggleDisplay_Click" HorizontalAlignment="Left"
                            Background="Transparent" Foreground="#FF888888"
                            FontSize="9" FontWeight="Bold" Padding="0" BorderThickness="0"
                            Cursor="Hand" Margin="0,0,0,2"/>

                    <StackPanel x:Name="DisplayContainer" Visibility="Collapsed" Margin="0,0,0,4">
                        <!-- Background opacity -->
                        <TextBlock Text="BACKGROUND OPACITY" Foreground="#FF555555" FontSize="8" FontWeight="Bold" Margin="0,0,0,2"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Alpha:" Foreground="#FF888888" FontSize="10" VerticalAlignment="Center"/>
                            <Slider x:Name="SliderBgOpacity" Grid.Column="1" Minimum="0" Maximum="100" Value="100"
                                    TickFrequency="1" IsSnapToTickEnabled="True" Margin="4,0" ValueChanged="SliderBgOpacity_ValueChanged"/>
                            <TextBlock x:Name="TxtBgOpacity" Grid.Column="2" Text="100%" Foreground="#FF00FFCC" FontSize="10" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Theme selector -->
                        <TextBlock Text="THEME" Foreground="#FF555555" FontSize="8" FontWeight="Bold" Margin="0,0,0,2"/>
                        <ComboBox x:Name="ComboTheme" Style="{StaticResource DarkCombo}" SelectionChanged="ComboTheme_SelectionChanged" Margin="0,0,0,8">
                            <ComboBoxItem Content="Carbon" IsSelected="True"/>
                            <ComboBoxItem Content="Neon Drift"/>
                            <ComboBoxItem Content="Anime Girl ♡"/>
                            <ComboBoxItem Content="Ferrari"/>
                            <ComboBoxItem Content="Night Sky"/>
                        </ComboBox>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="IMPORT FILE" Click="BtnImportFile_Click" Background="#FF333333" Height="22" FontSize="9" FontWeight="Bold" Margin="0,0,2,0"/>
                            <Button Content="SAVE LOCAL"  Click="BtnExport_Click" Grid.Column="1" Background="#FF333333" Height="22" FontSize="9" FontWeight="Bold" Margin="2,0,0,0"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>

                <!-- ROW 5: Footer — compact + scale + Ko-fi -->
                <Grid Grid.Row="5" Margin="0,5,0,2">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <!-- Compact toggle -->
                        <Button x:Name="BtnCompact" Content="▲" Click="BtnCompact_Click"
                                Width="16" Height="16" FontSize="9" Padding="0" Margin="0,0,6,0"
                                Background="#1AFFFFFF" Foreground="#55FFFFFF"
                                ToolTip="Hide/show settings"/>
                        <!-- Scale widget -->
                        <Button x:Name="BtnScaleMinus" Content="−" Click="BtnScaleMinus_Click"
                                Width="16" Height="16" FontSize="11" Padding="0"
                                Background="#1AFFFFFF" Foreground="#88FFFFFF"/>
                        <TextBlock x:Name="TxtScale" Text="100%" FontSize="8" FontWeight="Bold"
                                   Foreground="#55FFFFFF" VerticalAlignment="Center"
                                   Margin="4,0" MinWidth="28" TextAlignment="Center"/>
                        <Button x:Name="BtnScalePlus" Content="+" Click="BtnScalePlus_Click"
                                Width="16" Height="16" FontSize="11" Padding="0"
                                Background="#1AFFFFFF" Foreground="#88FFFFFF"/>
                    </StackPanel>
                    <!-- Ko-fi link -->
                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand">
                        <Hyperlink NavigateUri="https://ko-fi.com/christophersperl" RequestNavigate="KoFi_Click"
                                   TextDecorations="None">
                            <Run Text="☕ ko-fi.com/christophersperl" FontSize="8" Foreground="#33FFFFFF"/>
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>

        <Thumb Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Cursor="SizeNWSE" DragDelta="ResizeThumb_DragDelta" Margin="0,0,2,2">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Path Data="M 0,10 L 10,0 L 10,10 Z" Fill="#33FFFFFF"/>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
    </Grid>
</Window>
